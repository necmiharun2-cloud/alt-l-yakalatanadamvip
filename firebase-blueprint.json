{
  "entities": {
    "User": {
      "title": "User",
      "description": "App users and their roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "vip", "admin"] },
        "isVip": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Prediction": {
      "title": "Prediction",
      "description": "Match predictions and analyses",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subTitle": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string", "enum": ["current", "success"] },
        "isPublic": { "type": "boolean" },
        "winnings": { "type": "string" },
        "ayaklar": { "type": "array" },
        "fiyat": { "type": "string" },
        "commentsEnabled": { "type": "boolean" },
        "authorName": { "type": "string" },
        "views": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "type"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comments on predictions",
      "type": "object",
      "properties": {
        "predictionId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["predictionId", "userId", "content"]
    },
    "Blog": {
      "title": "Blog",
      "description": "Blog posts",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "views": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content"]
    },
    "SliderItem": {
      "title": "Slider Item",
      "description": "Homepage slider content",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subTitle": { "type": "string" },
        "ctaText": { "type": "string" },
        "ctaLink": { "type": "string" },
        "imageUrl": { "type": "string" },
        "orderIndex": { "type": "integer" },
        "active": { "type": "boolean" }
      },
      "required": ["title", "imageUrl"]
    },
    "Bank": {
      "title": "Bank Account",
      "description": "Payment bank accounts",
      "type": "object",
      "properties": {
        "bankName": { "type": "string" },
        "iban": { "type": "string" },
        "receiverName": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["bankName", "iban"]
    },
    "Payment": {
      "title": "Payment Notification",
      "description": "User payment notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "package": { "type": "string" },
        "bank": { "type": "string" },
        "reference": { "type": "string" },
        "amount": { "type": "string" },
        "note": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "package", "bank", "amount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Horse race predictions"
    },
    "/blogs/{blogId}": {
      "schema": "Blog",
      "description": "Blog posts"
    },
    "/slider/{sliderId}": {
      "schema": "SliderItem",
      "description": "Slider content"
    },
    "/banks/{bankId}": {
      "schema": "Bank",
      "description": "Bank details"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment notifications"
    }
  }
}
